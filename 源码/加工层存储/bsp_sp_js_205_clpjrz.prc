--票据种类是02的，承兑人名称、证件代码、证件类型按出票人刷
UPDATE PBOCD_JS_205_CLPJRZ
   SET ACCEPT_NAME    = DRAWER_NAME,
       ACCEPT_ID_TYPE = DRAWER_ID_TYPE,
       ACCEPT_ID_NO   = DRAWER_ID_NO
 WHERE CJRQ = IS_DATE
   AND BILL_TYPE = '02';
COMMIT;

