--[2025-04-27] [周立鹏] [JLBA202412270002_关于分析排查及改造金融基础数据取数逻辑的需求_一阶段][李楠] 剔除取上期/配置表
/*
--039801机构没有业务人员处理，需要我们自行处理
--同一承兑人证件代码对应不同承兑人名称的，刷承兑人人名称
MERGE INTO PBOCD_JS_205_CLPJRZ A
USING (SELECT DISTINCT ACCEPT_ID_NO, ACCEPT_NAME
         FROM PBOCD_JS_205_CLPJRZ_SQ
        WHERE CJRQ = VS_LAST_TEXT) B
ON (A.ACCEPT_ID_NO = B.ACCEPT_ID_NO)
WHEN MATCHED THEN
  UPDATE
     SET A.ACCEPT_NAME = B.ACCEPT_NAME
   WHERE A.CJRQ = IS_DATE
     AND A.ORG_NUM = '039801'
     AND EXISTS
   (SELECT 1
            FROM (SELECT ACCEPT_ID_NO, COUNT(1)
                    FROM (SELECT DISTINCT ACCEPT_ID_NO, ACCEPT_NAME
                            FROM PBOCD_JS_205_CLPJRZ
                           WHERE CJRQ = IS_DATE
                             AND ORG_NUM = '039801')
                   GROUP BY ACCEPT_ID_NO
                  HAVING COUNT(1) > 1) B
           WHERE A.ACCEPT_ID_NO = B.ACCEPT_ID_NO);
COMMIT;
--039801机构没有业务人员处理，需要我们自行处理
--贴现金额、贴现金额折人民币按上期刷
MERGE INTO PBOCD_JS_205_CLPJRZ A
USING (SELECT * FROM PBOCD_JS_205_CLPJRZ_SQ WHERE CJRQ = VS_LAST_TEXT) B
ON (A.BILL_NUM = B.BILL_NUM)
WHEN MATCHED THEN
  UPDATE
     SET A.DISCOUNT_BAL     = B.DISCOUNT_BAL,
         A.DISCOUNT_BAL_RMB = B.DISCOUNT_BAL_RMB
   WHERE A.CJRQ = IS_DATE
     AND ORG_NUM = '039801';
COMMIT;*/

----------------------------------------------------------------------------------------------
-- ZHOULP20251201 已交易日期(即放款日期)是20251031为结点，之前的不变，之后直转的忽略内部流转记录
--票据最长期限是半年，半年后存量过渡没了可删除此逻辑
EXECUTE IMMEDIATE 'truncate table JS_205_CLPJRZ_TMP3';

insert into JS_205_CLPJRZ_TMP3
  SELECT /*+ PARALLEL(8)*/
   T1.acct_Num,
   T1.draft_rng,
   T1.LOAN_ACCT_BAL  AS LOAN_ACCT_BAL_ZHITIE,
   T1.INT_ADJEST_AMT AS INT_ADJEST_AMT_ZHITIE,
   T2.LOAN_ACCT_BAL  AS LOAN_ACCT_BAL_ZHUANTIE,
   T2.INT_ADJEST_AMT AS INT_ADJEST_AMT_ZHUANTIE
    FROM SMTMODS.L_ACCT_LOAN T1
   INNER JOIN SMTMODS.L_ACCT_LOAN T2
      ON T2.DATA_DATE = IS_DATE
     AND SUBSTR(T2.ITEM_CD, 1, 6) IN ('130102', '130105')
     AND T1.acct_Num || T1.draft_rng = T2.acct_Num || T2.draft_rng
   WHERE T1.DATA_DATE = IS_DATE
     AND SUBSTR(T1.ITEM_CD, 1, 6) IN ('130101', '130104');
commit;
    
EXECUTE IMMEDIATE 'truncate table pbocd_js_205_clpjrz_20251201';

insert into pbocd_js_205_clpjrz_20251201
select * from pbocd_js_205_clpjrz a where a.cjrq = IS_DATE;
commit;

update pbocd_js_205_clpjrz a set discount_type = '02' 
where a.cjrq = IS_DATE and discount_type = '01' 
and exists(select 1 from pbocd_js_205_clpjrz_20251031 b where b.cjrq = '20251031' and b.discount_type = '02' and a.bill_num=b.bill_num)--写死20251031
and exists(select 1 from JS_205_CLPJRZ_TMP3 T where a.bill_num=T.acct_Num||T.draft_rng and NVL(T.LOAN_ACCT_BAL_ZHUANTIE,0) + NVL(T.INT_ADJEST_AMT_ZHUANTIE,0) <> 0);
----------------------------------------------------------------------------------------------

  OI_RETCODE := 0; --设置异常状态为0 成功状态
  OI_RETCODE_DEC :='执行成功';


  /*COMMIT; --非特殊处理只能在最后一次提交*/
  -- 结束日志
  VS_STEP := 'END';
  SP_PBOCD_LOG(VS_PROCEDURE_NAME, VS_STEP, VI_ERRORCODE, VS_TEXT, IS_DATE);
EXCEPTION
  WHEN OTHERS THEN
    --如果出现异常
    VI_ERRORCODE := SQLCODE; --设置异常代码
    VS_TEXT      := VS_STEP || '|' || IS_DATE || '|' ||
                    SUBSTR(SQLERRM, 1, 200); --设置异常描述
    ROLLBACK; --数据回滚
    OI_RETCODE := -1; --设置异常状态为-1
    OI_RETCODE_DEC :=SQLCODE||':'||SUBSTR(SQLERRM,1,50);--系统错误描述
    --插入日志表，记录错误
    SP_PBOCD_LOG(VS_PROCEDURE_NAME, 'ERROR', VI_ERRORCODE, VS_TEXT, IS_DATE);
END;
